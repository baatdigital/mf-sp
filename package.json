{
  "name": "@covacha/mf-sp",
  "version": "0.0.1",
  "description": "Micro-frontend SuperPago - Portal Multi-Tier (Admin / Business / Personal)",
  "private": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "ng": "ng",
    "start": "ng serve --port 4210",
    "start:dev": "ng serve --port 4210 --configuration development",
    "start:shell": "ng serve --port 4210 --open",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "build:dev": "ng build --configuration development",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "lint": "ng lint",
    "serve:mf": "http-server dist/mf-sp/browser -p 4210 --cors"
  },
  "dependencies": {
    "@angular-architects/native-federation": "21.0.4",
